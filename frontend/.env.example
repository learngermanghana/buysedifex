# Sedifex integration API (server-side)
SEDIFEX_INTEGRATION_API_BASE_URL=https://api.sedifex.com/integration
SEDIFEX_INTEGRATION_API_VERSION=v1
SEDIFEX_INTEGRATION_API_KEY=replace_with_integration_api_key

# Legacy Firebase values (only needed for leads/web-vitals APIs)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
