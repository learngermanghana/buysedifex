rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    // Public denormalized read model for buy.sedifex.com
    match /publicProducts/{publicProductId} {
      allow read: if true;
      allow write: if false; // Server-only via Admin SDK in Cloud Functions.
    }

    // Private canonical store data.
    match /stores/{storeId} {
      allow read, update, delete: if isStoreOwner(storeId);
      allow create: if isSignedIn() && request.auth.uid == storeId;

      match /products/{productId} {
        allow read, write: if isStoreOwner(storeId);
      }
    }
  }
}
